# Environment variables for wc2026prediction
# Copy this file to .env and fill in your values
# Never commit .env to Git

# ─── Required ─────────────────────────────────────────────────────────────────

# API-Football API key
# Get yours free at: https://www.api-football.com/
# Free tier: 500 requests/day (we use ~20 per update)
API_FOOTBALL_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# The Odds API key — for betting market implied probabilities
# Get yours free at: https://the-odds-api.com/
# Free tier: 500 requests/month (we use ~6 per month)
# If not set, the betting signal is skipped and weight redistributed to Elo
ODDS_API_KEY=

# ─── Runtime config (override defaults from config.py) ────────────────────────

# Logging level: DEBUG, INFO, WARNING (default: INFO)
# LOG_LEVEL=INFO

# Number of Monte Carlo simulations (default: 10000)
# Higher = more accurate but slower. 10000 is the sweet spot.
# N_SIMULATIONS=10000
